<%- include('partials/header') %>

<% if (blog) { %>
<div
  id="blogDetailsPage"
  class="max-w-6xl mx-auto w-full px-4 md:px-0 animate-fade-in"
>
  <div class="mb-8">
    <a
      href="javascript:history.back()"
      class="inline-flex items-center gap-2 text-slate-500 hover:text-[#7E43E2] transition-colors text-sm font-medium"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"
        />
      </svg>
      Back To Home
    </a>
  </div>

  <div
    class="bg-white/80 backdrop-blur-sm border border-[#e8c4b8]/30 rounded-3xl p-8 md:p-20 shadow-sm relative overflow-hidden"
  >
    <div
      class="absolute -top-24 -right-24 w-64 h-64 bg-gradient-to-br from-[#FF714D]/20 to-[#FFB347]/20 rounded-full blur-3xl -z-10 pointer-events-none"
    ></div>

    <h1
      id="blogTitle"
      class="text-4xl md:text-5xl font-extrabold text-slate-800 mb-8 font-[Georgia] leading-tight text-transparent bg-clip-text bg-gradient-to-r from-slate-800 to-slate-600"
    ><%= blog?.title %>
    <div class="absolute top-6 right-10 z-50 flex gap-2">
      <% if(blog?.author.id == user?.id ) { %>
      <div
      onclick="window.location.href = '/edit-blog/<%= blog?.id %>'"
      data-id="<%= blog?.id %>"
        class="flex gap-1 items-center text-sm text-[#5660f0] bg-transparent border-1 border-[#5660f0]/50 hover:bg-blue-200/10 hover:shadow-lg hover:shadow-slate-500/50 hover:-translate-y-0.5 duration-300 transition-all px-3 py-1 rounded-lg font-semibold cursor-pointer"
      >
        <span>
          <svg viewBox="0 0 24 24" class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path stroke="#5660f0" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.5 7.5l3 3M4 20v-3.5L15.293 5.207a1 1 0 011.414 0l2.086 2.086a1 1 0 010 1.414L7.5 20H4z"></path> </g></svg>
        </span>Edit Blog
      </div>
      <% } %>
    <% if(blog?.author.id == user?.id || user?.roles.some(role => role.roleName === 'ADMIN') || user?.roles.some(role => role.roleName === 'SUPER_ADMIN')) { %>
    <div
      onclick="if(confirm(`Are you sure you want to delete this blog?`)) deleteBlog(`<%= blog?.id %>`)"
      data-id="<%= blog?.id %>"
      class="flex gap-1 items-center text-sm text-red-500 bg-red-50 hover:bg-red-500 border-1 border-red-500/50 hover:text-white hover:shadow-lg hover:shadow-red-500/50 hover:-translate-y-0.5 duration-300 transition-all px-3 py-1 rounded-lg font-semibold cursor-pointer"
    >
      <span>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </span>Delete Blog
    </div>
    <% } %>
    </div>
    </h1>

    <div class="flex flex-wrap items-center gap-4 md:gap-6 pb-8">
      <div class="flex gap-2 items-center">
        <svg
          class="w-6 h-6 text-[#7E43E2]"
          fill="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"
          />
        </svg>

        <a
          id="blogAuthor"
          href="/author/<%= blog?.author ? blog?.author.id : '#' %>"
          class="text-md font-bold text-slate-700 hover:text-[#7E43E2] transition-colors"
        ><%= blog?.author ? blog?.author.username : 'Unknown' %></a>
      </div>

      <span
        id="blogTime"
        class="text-slate-400 text-sm font-medium flex items-center gap-1.5"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"
          />
        </svg>
        <span class="time-text"><%= new Date(blog?.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
      </span>

      <span
        id="blogCategory"
        class="px-4 py-1.5 bg-[#FF714D]/10 text-[#FF714D] text-xs font-semibold uppercase tracking-wider rounded-xl"
      ><%= blog?.category || 'Blog' %></span>
    </div>

    <div class="border-y-2 border-slate-100 px-6 py-2 flex gap-10 items-center">
      <div
        onclick="<%= blog?.liked ? 'handleUnlike(`' + blog.id + '`)' : 'handleLike(`' + blog.id + '`)' %>"
        class="flex gap-1 items-center cursor-pointer">
        <svg id="likeIcon" viewBox="0 0 24 24" class="w-4 h-4" style="color: <%= blog?.liked ? '#FF714D' : '#1C274C' %>" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M20.9752 12.1852L20.2361 12.0574L20.9752 12.1852ZM20.2696 16.265L19.5306 16.1371L20.2696 16.265ZM6.93777 20.4771L6.19056 20.5417L6.93777 20.4771ZM6.12561 11.0844L6.87282 11.0198L6.12561 11.0844ZM13.995 5.22142L14.7351 5.34269V5.34269L13.995 5.22142ZM13.3323 9.26598L14.0724 9.38725V9.38725L13.3323 9.26598ZM6.69814 9.67749L6.20855 9.10933H6.20855L6.69814 9.67749ZM8.13688 8.43769L8.62647 9.00585H8.62647L8.13688 8.43769ZM10.5181 4.78374L9.79208 4.59542L10.5181 4.78374ZM10.9938 2.94989L11.7197 3.13821V3.13821L10.9938 2.94989ZM12.6676 2.06435L12.4382 2.77841L12.4382 2.77841L12.6676 2.06435ZM12.8126 2.11093L13.042 1.39687L13.042 1.39687L12.8126 2.11093ZM9.86195 6.46262L10.5235 6.81599V6.81599L9.86195 6.46262ZM13.9047 3.24752L13.1787 3.43584V3.43584L13.9047 3.24752ZM11.6742 2.13239L11.3486 1.45675V1.45675L11.6742 2.13239ZM3.9716 21.4707L3.22439 21.5353L3.9716 21.4707ZM3 10.2342L3.74721 10.1696C3.71261 9.76945 3.36893 9.46758 2.96767 9.4849C2.5664 9.50221 2.25 9.83256 2.25 10.2342H3ZM20.2361 12.0574L19.5306 16.1371L21.0087 16.3928L21.7142 12.313L20.2361 12.0574ZM13.245 21.25H8.59635V22.75H13.245V21.25ZM7.68498 20.4125L6.87282 11.0198L5.3784 11.149L6.19056 20.5417L7.68498 20.4125ZM19.5306 16.1371C19.0238 19.0677 16.3813 21.25 13.245 21.25V22.75C17.0712 22.75 20.3708 20.081 21.0087 16.3928L19.5306 16.1371ZM13.2548 5.10015L12.5921 9.14472L14.0724 9.38725L14.7351 5.34269L13.2548 5.10015ZM7.18773 10.2456L8.62647 9.00585L7.64729 7.86954L6.20855 9.10933L7.18773 10.2456ZM11.244 4.97206L11.7197 3.13821L10.2678 2.76157L9.79208 4.59542L11.244 4.97206ZM12.4382 2.77841L12.5832 2.82498L13.042 1.39687L12.897 1.3503L12.4382 2.77841ZM10.5235 6.81599C10.8354 6.23198 11.0777 5.61339 11.244 4.97206L9.79208 4.59542C9.65573 5.12107 9.45699 5.62893 9.20042 6.10924L10.5235 6.81599ZM12.5832 2.82498C12.8896 2.92342 13.1072 3.16009 13.1787 3.43584L14.6307 3.05921C14.4252 2.26719 13.819 1.64648 13.042 1.39687L12.5832 2.82498ZM11.7197 3.13821C11.7548 3.0032 11.8523 2.87913 11.9998 2.80804L11.3486 1.45675C10.8166 1.71309 10.417 2.18627 10.2678 2.76157L11.7197 3.13821ZM11.9998 2.80804C12.1345 2.74311 12.2931 2.73181 12.4382 2.77841L12.897 1.3503C12.3873 1.18655 11.8312 1.2242 11.3486 1.45675L11.9998 2.80804ZM14.1537 10.9842H19.3348V9.4842H14.1537V10.9842ZM4.71881 21.4061L3.74721 10.1696L2.25279 10.2988L3.22439 21.5353L4.71881 21.4061ZM3.75 21.5127V10.2342H2.25V21.5127H3.75ZM3.22439 21.5353C3.2112 21.3828 3.33146 21.25 3.48671 21.25V22.75C4.21268 22.75 4.78122 22.1279 4.71881 21.4061L3.22439 21.5353ZM14.7351 5.34269C14.8596 4.58256 14.8241 3.80477 14.6307 3.0592L13.1787 3.43584C13.3197 3.97923 13.3456 4.54613 13.2548 5.10016L14.7351 5.34269ZM8.59635 21.25C8.12244 21.25 7.72601 20.887 7.68498 20.4125L6.19056 20.5417C6.29852 21.7902 7.3427 22.75 8.59635 22.75V21.25ZM8.62647 9.00585C9.30632 8.42 10.0392 7.72267 10.5235 6.81599L9.20042 6.10924C8.85404 6.75767 8.3025 7.30493 7.64729 7.86954L8.62647 9.00585ZM21.7142 12.313C21.9695 10.8365 20.8341 9.4842 19.3348 9.4842V10.9842C19.9014 10.9842 20.3332 11.4959 20.2361 12.0574L21.7142 12.313ZM3.48671 21.25C3.63292 21.25 3.75 21.3684 3.75 21.5127H2.25C2.25 22.1953 2.80289 22.75 3.48671 22.75V21.25ZM12.5921 9.14471C12.4344 10.1076 13.1766 10.9842 14.1537 10.9842V9.4842C14.1038 9.4842 14.0639 9.43901 14.0724 9.38725L12.5921 9.14471ZM6.87282 11.0198C6.8474 10.7258 6.96475 10.4378 7.18773 10.2456L6.20855 9.10933C5.62022 9.61631 5.31149 10.3753 5.3784 11.149L6.87282 11.0198Z" fill="currentColor"></path> </g></svg>
        <span id="likesCount"><%= blog?.likeCount %></span>
        <span id="likesText">Like</span>
      </div>
    </div>

    <div
      id="blogContent"
      class="prose prose-slate font-bold prose-lg max-w-none prose-headings:font-[Georgia] prose-headings:text-slate-800 prose-a:text-[#7E43E2] whitespace-pre-line prose-a:no-underline hover:prose-a:underline prose-p:leading-relaxed prose-p:text-slate-600"
    >
      <%- blog?.content %>
    </div>

    <div class="border-t-2 border-slate-100 mt-10 p-2 pt-5">
      <div class="flex gap-4 items-center">
        <div
          class="w-12 h-12 rounded-full bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center"
        >
          <span id="authInitals" class="text-2xl font-bold text-slate-500"><%= blog.author ? blog.author.username.charAt(0).toUpperCase() : '?' %></span>
        </div>
        <div class="flex flex-col">
          <span>Written By</span>
          <a
            href="/author/<%= blog?.author ? blog?.author.id : '#' %>"
            class="text-md font-bold text-slate-700 hover:text-[#7E43E2] transition-colors"
          >
            <%= blog?.author ? blog?.author.username : 'Unknown' %>
          </a>
        </div>
      </div>
    </div>
  </div>
</div>
<% } else { %>
<div
  id="blogNotFound"
  class="max-w-lg mx-auto text-center py-16 animate-fade-in"
>
  <div
    class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-4"
  >
    <svg
      class="w-8 h-8 text-red-400"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
      />
    </svg>
  </div>
  <h2 class="text-xl font-bold text-slate-800 mb-2">Blog Not Found</h2>
  <p class="text-slate-500 font-medium mb-6">
    The post you are looking for doesn't exist or has been removed.
  </p>
  <a
    href="/"
    class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-white font-semibold bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] shadow-md shadow-[#7E43E2]/25 transition-all hover:-translate-y-0.5"
  >
    Return Home
  </a>
</div>
<% } %>

<%- include('partials/footer') %>

<script>
  const fetchOptions = {
        headers: { "Content-Type": "application/json" },
        };
        
    const deleteBlog = async (blogId) => {

    try {
      const res = await fetch("/blog/delete-blog", {
        method: "DELETE",
        ...fetchOptions,
        body: JSON.stringify({ id: blogId }),
      });
      const data = await res.json();

      if (res.ok) {
        window.location.href = "/";
      } else {
        alert(data.message || "Failed to delete blog.");
      }
    } catch (err) {
      alert("An error occurred connecting to the server.");
    }
}

    const handleLike = async (blogId) => {
        try {
            const res = await fetch(`/blog/like-blog?id=${blogId}`, {
                method: "POST",
                ...fetchOptions
            });
            const data = await res.json();
            if(res.ok){
                window.location.reload();
            }else{
                alert(data.message || "Failed to like blog.")
            }
        } catch (err) {
            alert("An error occurred connecting to the server.")
        }
    }

    const handleUnlike = async (blogId) => {
      try {
        const res = await fetch(`/blog/unlike-blog?id=${blogId}`, {
          method: "DELETE",
          ...fetchOptions
        })
        const data = await res.json()
        if (res.ok) {
          window.location.reload();
        } else {
          alert(data.message || "Failed to unlike blog.");
        }
      } catch (err) {
        alert("An error occurred connecting to the server.");
      }
    };
</script>
