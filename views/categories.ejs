        };
        const DESC_MAP = {
            "Design": "UI/UX, graphic design, and creative processes",
            "Technology": "Software, hardware, and tech trends",
            "Art & Culture": "Paintings, history, and cultural phenomena",
            "Education": "Learning strategies and educational tools",
            "Entertainment": "Movies, music, games, and pop culture",
            "Lifestyle": "Daily habits, productivity, and personal growth",
            "Health & Wellness": "Physical and mental health tips",
            "Travel": "Destinations, tips, and travel stories",
            "Finance": "Personal finance, investing, and markets",
            "Science": "Discoveries, research, and scientific theories",
            "Food & Cooking": "Recipes, reviews, and culinary arts",
            "Sports": "Athletics, competitions, and fitness",
            "Programming": "Coding tutorials, languages, and frameworks",
            "Startups": "Entrepreneurship, business, and growth"
        };
        %>
        <% categories.forEach(category => { %>
            <a href="/blogs?category=<%= encodeURIComponent(category.name) %>" class="category-link block bg-white/80 backdrop-blur-sm border border-[#e8c4b8]/30 rounded-2xl p-6 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-[#7E43E2]/8 transition-all duration-300 group">
                <div class="flex items-start justify-between mb-4">
                    <div class="category-emoji w-12 h-12 rounded-xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform duration-300">
                        <%- EMOJI_MAP[category.name] || '<svg class="w-6 h-6 text-[#7E43E2]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>' %>
                    </div>
                    <span class="category-count text-xs font-bold text-[#7E43E2] bg-[#7E43E2]/8 px-3 py-1 rounded-full"><%= category.count %> posts</span>
                </div>
                <h3 class="category-name text-lg font-bold text-slate-800 group-hover:text-[#7E43E2] transition-colors duration-200 font-[Georgia]"><%= category.name %></h3>
                <p class="category-desc text-slate-500 text-sm mt-1.5 leading-relaxed"><%= DESC_MAP[category.name] || 'Explore posts in ' + category.name %></p>
                <div class="flex items-center gap-1.5 mt-4 text-sm font-semibold text-[#FF714D] opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    Browse posts
                    <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
                </div>
            </a>
        <% }) %>
    <% } %>
</div>

