<%- include('partials/header') %>

<div class="flex flex-col md:flex-row justify-between items-center pb-8 min-h-[75vh] gap-12 animate-fade-in">
    <div class="flex flex-col justify-center w-full">
        <h1 class="font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] mb-3 tracking-wider text-2xl animate-slide-up">Hi There,</h1>
        <p class="text-slate-800 font-extrabold text-4xl md:text-5xl font-[Georgia] leading-tight md:leading-15 animate-slide-up stagger-1" style="opacity:0;">I'm Roushan Srivastava, a Software Developer & Tech Blogger.</p>
        <p class="mt-4 font-normal text-slate-500 text-lg max-w-3xl animate-slide-up stagger-2" style="opacity:0;">A collection of thoughts, experiments, and insights that don't fit into tweets.</p>
        <div class="mt-12 flex gap-4 animate-slide-up stagger-3" style="opacity:0;">
            <a class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-white bg-gradient-to-r from-[#FF714D] to-[#FFB347] hover:from-[#e8643f] hover:to-[#f0a73d] transition-all duration-300 shadow-lg shadow-orange-500/25 hover:shadow-xl hover:shadow-orange-500/30 hover:-translate-y-0.5" href="/blog/<%= locals.superBlogId || 1 %>">
                Start Reading
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
            <a class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-slate-700 border-2 border-slate-300 hover:border-[#7E43E2] hover:text-[#7E43E2] hover:bg-[#7E43E2]/5 transition-all duration-300 hover:-translate-y-0.5" href="/author/<%= locals.superAdminId || 1 %>">View Profile</a>
        </div>
    </div>
    <div class="flex justify-center w-full animate-fade-in stagger-3" style="opacity:0;">
        <div class="w-72 h-72 md:w-90 md:h-90 overflow-hidden rounded-3xl border-2 border-white/40 shadow-2xl shadow-[#7E43E2]/15 rotate-6 hover:rotate-0 transition-transform duration-500">
            <img
                src="images/the_only.jpg"
                alt="Roushan Srivastava"
                class="w-full h-full object-cover -rotate-6 hover:rotate-0 scale-116 object-top transition-transform duration-500"
            />
        </div>
    </div>
</div>

<div class="w-full rounded-2xl flex flex-col gap-10 items-center justify-center bg-gradient-to-r from-[#FF714D]/50 to-[#FFB347]/40 backdrop-blur-sm font-[Georgia] p-8 border border-[#e8c4b8]/30 mt-10 shadow-sm animate-fade-in-up" style="opacity:0;">
    <div class="text-center">
        <h2 class="text-3xl font-extrabold text-slate-800">Popular Categories</h2>
        <div class="w-16 h-1 bg-[#7E43E2] rounded-full mx-auto mt-3"></div>
    </div>
    <div class="flex gap-6 md:gap-12 justify-between flex-wrap items-center w-full px-4 md:px-10">
        <a href="/blogs?category=Design" class="flex flex-col items-center justify-center gap-3 cursor-pointer group no-underline">
            <div class="w-20 h-20 md:w-25 md:h-25 rounded-xl overflow-hidden border-2 border-transparent group-hover:border-[#7E43E2]/30 transition-all duration-300 group-hover:-translate-y-1 shadow-sm group-hover:shadow-md"><img src="images/design.avif" alt="Design" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-300"></div>
            <div class="text-slate-700 font-semibold text-sm group-hover:text-[#7E43E2] transition-colors">Design</div>
        </a>
        <a href="/blogs?category=Technology" class="flex flex-col items-center justify-center gap-3 cursor-pointer group no-underline">
            <div class="w-20 h-20 md:w-25 md:h-25 rounded-xl overflow-hidden border-2 border-transparent group-hover:border-[#7E43E2]/30 transition-all duration-300 group-hover:-translate-y-1 shadow-sm group-hover:shadow-md"><img src="images/tech.jpg" alt="Technology" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-300"></div>
            <div class="text-slate-700 font-semibold text-sm group-hover:text-[#7E43E2] transition-colors">Technology</div>
        </a>
        <a href="/blogs?category=Art %26 Culture" class="flex flex-col items-center justify-center gap-3 cursor-pointer group no-underline">
            <div class="w-20 h-20 md:w-25 md:h-25 rounded-xl overflow-hidden border-2 border-transparent group-hover:border-[#7E43E2]/30 transition-all duration-300 group-hover:-translate-y-1 shadow-sm group-hover:shadow-md"><img src="images/art.avif" alt="Art & Culture" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-300"></div>
            <div class="text-slate-700 font-semibold text-sm group-hover:text-[#7E43E2] transition-colors">Art & Culture</div>
        </a>
        <a href="/blogs?category=Education" class="flex flex-col items-center justify-center gap-3 cursor-pointer group no-underline">
            <div class="w-20 h-20 md:w-25 md:h-25 rounded-xl overflow-hidden border-2 border-transparent group-hover:border-[#7E43E2]/30 transition-all duration-300 group-hover:-translate-y-1 shadow-sm group-hover:shadow-md"><img src="images/education.jpg" alt="Education" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-300"></div>
            <div class="text-slate-700 font-semibold text-sm group-hover:text-[#7E43E2] transition-colors">Education</div>
        </a>
        <a href="/blogs?category=Entertainment" class="flex flex-col items-center justify-center gap-3 cursor-pointer group no-underline">
            <div class="w-20 h-20 md:w-25 md:h-25 rounded-xl overflow-hidden border-2 border-transparent group-hover:border-[#7E43E2]/30 transition-all duration-300 group-hover:-translate-y-1 shadow-sm group-hover:shadow-md"><img src="images/entertainment.jpg" alt="Entertainment" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-300"></div>
            <div class="text-slate-700 font-semibold text-sm group-hover:text-[#7E43E2] transition-colors">Entertainment</div>
        </a>
        <a href="/blogs?category=Lifestyle" class="flex flex-col items-center justify-center gap-3 cursor-pointer group no-underline">
            <div class="w-20 h-20 md:w-25 md:h-25 rounded-xl overflow-hidden border-2 border-transparent group-hover:border-[#7E43E2]/30 transition-all duration-300 group-hover:-translate-y-1 shadow-sm group-hover:shadow-md"><img src="images/lifestyle.avif" alt="Lifestyle" class="object-cover w-full h-full group-hover:scale-110 transition-transform duration-300"></div>
            <div class="text-slate-700 font-semibold text-sm group-hover:text-[#7E43E2] transition-colors">Lifestyle</div>
        </a>
    </div>
    <div class="flex justify-center items-center">
        <a href="/categories" class="cursor-pointer border-2 border-[#7E43E2]/40 px-6 py-2.5 rounded-xl font-bold text-[#7E43E2] hover:border-[#7E43E2]/40 hover:bg-[#7E43E2]/5 transition-all duration-300 hover:-translate-y-0.5 no-underline">Explore More</a>
    </div>
</div>

<div class="mt-16 mb-4">
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-3xl font-extrabold text-slate-800 font-[Georgia]">Latest Posts</h2>
            <div class="w-12 h-1 bg-orange-500 mt-2"></div>
        </div>
    </div>
</div>

<div id="blogFeed" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% if (locals.user && locals.user.roles.some(r => r.roleName === 'READER' && r.isApproved)) { %>
        <% if (blogs.length === 0) { %>
            <div class="col-span-full text-center py-16">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-[#7E43E2]/50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                </div>
                <p class="text-slate-500 font-medium">No blogs found.</p>
                <p class="text-slate-400 text-sm mt-1">Try a different category or check back later.</p>
            </div>
        <% } else { %>
            <% blogs.forEach((blog) => { %>
                <a href="/blog/<%= blog.id %>" class="blog-card-clickable bg-white/80 backdrop-blur-sm border border-[#e8c4b8]/30 rounded-2xl overflow-hidden hover:-translate-y-1.5 hover:shadow-xl hover:shadow-[#7E43E2]/8 transition-all duration-300 group cursor-pointer block no-underline">
                    <div class="p-6 flex flex-col justify-between h-full">
                        <div>
                        <div class="flex items-center gap-2 mb-4">
                            <div class="text-slate-400 text-xs">Category:</div>
                            <span class="blog-category text-xs font-semibold text-[#7E43E2] uppercase tracking-wider"><%= blog.category || 'Blog' %></span>
                        </div>
                        <h2 class="blog-title text-xl font-bold text-slate-800 mb-3 line-clamp-2 group-hover:text-[#7E43E2] transition-colors duration-200 font-[Georgia]"><%= blog.title %></h2>
                        <p class="blog-excerpt text-slate-500 mb-6 line-clamp-3 text-sm leading-relaxed"><%= blog.content %></p>
                        </div>
                        <div class="flex justify-between gap-4 border-t border-[#e8c4b8]/30">
                            <div class="blog-meta text-xs text-slate-400 pt-4 flex items-center gap-2 relative z-10">
                                <div class="w-6 h-6 rounded-full bg-gradient-to-br from-[#7E43E2]/20 to-[#FF714D]/20 flex items-center justify-center">
                                    <svg class="w-3 h-3 text-[#7E43E2]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                                </div>
                                <span class="font-medium text-slate-500 group-hover:text-[#7E43E2] transition-colors"><%= blog.author ? blog.author.username : 'Unknown' %></span>
                            </div>
                            <div class="pt-4">
                                <span class="blog-time text-slate-500 text-xs"><%= new Date(blog.createdAt).toLocaleDateString() %></span>
                            </div>
                        </div>
                    </div>
                </a>
            <% }) %>
        <% } %>
    <% } else { %>
        <div class="col-span-full text-center py-16">
            <% if (!locals.user) { %>
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-[#7E43E2]/50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
                </div>
                <p class="text-slate-500 font-medium">Login to view blogs</p>
                <a href="/login" class="inline-flex items-center gap-2 mt-4 px-5 py-2.5 rounded-xl text-white font-semibold bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] hover:from-[#6E35D0] hover:to-[#8B49D8] shadow-md shadow-[#7E43E2]/25 transition-all hover:-translate-y-0.5">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                    Login Now
                </a>
            <% } else { %>
                <div class="w-20 h-20 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-6">
                    <svg class="w-10 h-10 text-[#7E43E2]/60" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
                </div>
                <h2 class="text-2xl font-extrabold text-slate-800 font-[Georgia] mb-3">Reader Access Required</h2>
                <p class="text-slate-500 mb-8 max-w-sm mx-auto">You need to be a Reader to read blog posts. Request access in your Settings.</p>
                <a href="/settings#request-role" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl font-semibold text-white bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] shadow-md shadow-[#7E43E2]/25 transition-all duration-300 hover:shadow-lg hover:-translate-y-0.5 cursor-pointer">
                    Request Reader Access
                </a>
            <% } %>
        </div>
    <% } %>
</div>

<% if (locals.user && locals.user.roles.some(r => r.roleName === 'READER' && r.isApproved) && blogs.length > 0) { %>
<div id="viewAllPostsBtn" class="flex justify-center mt-10">
    <a href="/blogs" class="inline-flex items-center gap-2 px-7 py-3 rounded-xl font-semibold text-[#7E43E2] border-2 border-[#7E43E2]/30 hover:border-[#7E43E2]/60 hover:bg-[#7E43E2]/5 transition-all duration-300 hover:-translate-y-0.5">
        View All Posts
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    </a>
</div>
<% } %>

<%- include('partials/footer') %>
