<%- include('partials/header') %>

<div class="flex justify-center items-center min-h-[65vh] animate-fade-in">
    <div class="w-full max-w-md">
        <div class="h-1.5 bg-orange-500 rounded-t-2xl"></div>
        
        <div class="bg-white/80 backdrop-blur-sm p-6 sm:p-10 rounded-b-2xl rounded-t-none border border-[#e8c4b8]/30 border-t-0 shadow-xl shadow-[#7E43E2]/5">
            <div class="text-center mb-8">
                <div class="w-14 h-14 rounded-2xl bg-orange-500 flex items-center justify-center mx-auto mb-4 shadow-lg shadow-[#7E43E2]/25">
                    <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                </div>
                <h2 class="text-3xl font-extrabold text-slate-800 font-[Georgia]">Welcome Back</h2>
                <p class="text-slate-500 mt-2">Login to your account</p>
            </div>
            
            <form id="loginForm" class="space-y-5">
                <div id="loginError" class="bg-red-50 border border-red-200 text-red-600 p-4 rounded-xl text-sm" style="display: none;"></div>
                
                <div>
                    <label for="email" class="block mb-2 text-sm font-semibold text-slate-700">Email Address</label>
                    <input type="email" id="email" name="email" required placeholder="Enter your email" class="w-full p-3.5 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:border-[#7E43E2] focus:ring-2 focus:ring-[#7E43E2]/20 transition-all duration-200">
                </div>
                
                <div>
                    <label for="password" class="block mb-2 text-sm font-semibold text-slate-700">Password</label>
                    <input type="password" id="password" name="password" required placeholder="Enter your password" class="w-full p-3.5 rounded-xl border border-slate-200 bg-white text-slate-800 placeholder-slate-400 focus:outline-none focus:border-[#7E43E2] focus:ring-2 focus:ring-[#7E43E2]/20 transition-all duration-200">
                </div>
                
                <button type="submit" class="w-full bg-gradient-to-r from-[#FF714D] to-[#FFB347] hover:from-[#e8643f] hover:to-[#f0a73d] text-white font-semibold py-3.5 px-4 rounded-xl transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-orange-400/50 shadow-lg shadow-orange-500/20 hover:shadow-xl hover:shadow-orange-500/25 hover:-translate-y-0.5 cursor-pointer mt-2">Login</button>
            </form>
            
            <p class="text-center mt-8 text-sm text-slate-500">Don't have an account? <a href="/register" class="text-[#7E43E2] hover:text-[#6E35D0] font-semibold hover:underline decoration-2 underline-offset-2 transition-colors">Register here</a></p>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
