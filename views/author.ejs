<%- include('partials/header') %>

<% if (!author) { %>
<div id="authorNotFound" class="max-w-lg mx-auto text-center py-16 animate-fade-in">
    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
    </div>
    <h2 class="text-xl font-bold text-slate-800 mb-2">Author Not Found</h2>
    <p class="text-slate-500 font-medium mb-6">The author you are looking for doesn't exist or has been removed.</p>
    <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-white font-semibold bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] shadow-md shadow-[#7E43E2]/25 transition-all hover:-translate-y-0.5">
        Return Home
    </a>
</div>
<% } else { %>
<div id="authorPage" class="max-w-6xl mx-auto w-full animate-fade-in">
    <div class="relative mb-4">
        <div class="rounded-2xl bg-gradient-to-r from-[#FF714D]/50 to-[#FFB347]/40 backdrop-blur-sm shadow-lg shadow-[#7E43E2]/15 p-6">
        <div class="flex flex-col md:flex-row items-center md:items-end gap-4 px-2 md:px-6">
            <div id="profileAvatar" class="w-32 h-32 md:w-36 md:h-36 rounded-full bg-gradient-to-br from-[#7E43E2] to-[#9B59E8] flex items-center justify-center text-white text-4xl md:text-5xl font-extrabold border-4 border-[#FFF7F3] shadow-xl translate-y-16 md:translate-y-20 relative">
                <%= author.username.charAt(0).toUpperCase() %>
            </div>
        </div>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8 bg-white rounded-xl shadow-sm">
        <div class="p-6 pt-20 md:p-16 md:pb-4 flex flex-col gap-1 items-center md:items-start text-center md:text-left">
            <span class="text-2xl font-bold text-slate-800"><%= author.username %></span>
            <span class="text-md font-semibold text-slate-500">Joined <%= new Date(author.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' }) %></span>
        </div>

        <div class="col-span-1 md:col-span-2 px-6 md:px-16 pt-0 flex flex-col gap-1 pb-4 text-center md:text-left">
            <span class="font-semibold text-md text-slate-500">About Author</span>
            <p class="text-sm font-semibold"><%- author.aboutMe || 'No details provided.' %></p>
        </div>

        <div class="col-span-1 md:col-span-2 px-6 md:px-16 pb-10 grid grid-cols-1 sm:grid-cols-2 gap-6">

            <div class="group bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-6 flex flex-col justify-between min-h-36">
                <span class="text-sm font-semibold uppercase tracking-wider text-slate-500">
                    Posts
                </span>
                <span class="text-5xl font-bold text-slate-900 transition-colors">
                    <%= author.blogCount %>
                </span>
            </div>

            <div class="group bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 p-6 flex flex-col justify-between min-h-36">
                <span class="text-sm font-semibold uppercase tracking-wider text-slate-500">
                    Likes Received
                </span>
                <span class="text-5xl font-bold text-slate-900 transition-colors">
                    <%= author.likeCount %>
                </span>
            </div>

        </div>
    </div>

    <div class="mb-8">
        <% 
            const hasReaderAccess = locals.user && locals.roles && locals.roles.includes('READER');
        %>
        
        <h2 class="text-2xl font-bold text-slate-800 mb-6 font-[Georgia] border-b pb-2">Published Blogs</h2>
        
        <% if (!hasReaderAccess) { %>
            <div id="notReaderMessage" class="bg-white/80 backdrop-blur-sm border border-[#e8c4b8]/30 rounded-2xl p-8 text-center shadow-sm">
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-[#7E43E2]/60" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/></svg>
                </div>
                <h3 class="text-xl font-bold text-slate-800 mb-2">Reader Access Required</h3>
                <p class="text-slate-500 mb-6 max-w-md mx-auto">You need Reader permissions to view this author's published blogs.</p>
                <a href="/settings#request-role" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-semibold text-white bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] hover:from-[#6E35D0] hover:to-[#8B49D8] transition-all hover:-translate-y-0.5">
                    Request Reader Access
                </a>
            </div>
        <% } else { %>
            <div id="authorBlogFeed" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
                <% if (!blogs || blogs.length === 0) { %>
                    <div class="col-span-full text-center py-16">
                        <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[#7E43E2]/10 to-[#FF714D]/10 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-[#7E43E2]/50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                        </div>
                        <p class="text-slate-500 font-medium">No blogs found.</p>
                    </div>
                <% } else { %>
                    <% blogs.forEach(blog => { %>
                        <a href="/blog/<%= blog.id %>" class="group relative flex flex-col justify-between h-full bg-white/80 backdrop-blur-sm border border-[#e8c4b8]/30 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:shadow-[#7E43E2]/10 hover:-translate-y-1 transition-all duration-300">
                            <div>
                                <div class="flex items-center gap-1 mb-4">
                                    <span class="text-slate-500 text-xs">Category:</span><span class=" text-[#FF714D] text-xs font-bold uppercase tracking-wider"><%= blog.category || 'Blog' %></span>
                                </div>
                                <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-[#7E43E2] transition-colors font-[Georgia] line-clamp-2"><%= blog.title %></h3>
                                <p class="text-slate-600 text-sm line-clamp-3 leading-relaxed"><%= blog.content %></p>
                            </div>
                            <div class="mt-6 pt-4 border-t border-slate-100 flex items-center justify-between text-xs text-slate-400">
                                <div class="flex items-center gap-2 relative z-10">
                                    <div class="w-6 h-6 rounded-full bg-gradient-to-br from-[#7E43E2]/20 to-[#FF714D]/20 flex items-center justify-center">
                                        <svg class="w-3 h-3 text-[#7E43E2]" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
                                    </div>
                                    <span class="font-medium text-slate-500"><%= blog.author?.username || 'Unknown User' %></span>
                                </div>
                                <span class="font-medium"><%= new Date(blog.createdAt).toLocaleDateString() %></span>
                            </div>
                        </a>
                    <% }) %>
                <% } %>
            </div>
            
            <div id="authorPagination" class="flex justify-center gap-2 mt-12 mb-8">
                <% if (totalPages > 1) { %>
                    <a href="?page=<%= Math.max(1, currentPage - 1) %>" class="px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-200 <%= currentPage === 1 ? 'text-slate-300 pointer-events-none' : 'text-slate-600 hover:bg-[#7E43E2]/10 hover:text-[#7E43E2] border border-slate-200 hover:border-[#7E43E2]/30' %>">&laquo;</a>
                    
                    <% 
                    let pages = [];
                    if (totalPages <= 7) {
                        for (let i = 1; i <= totalPages; i++) pages.push(i);
                    } else {
                        pages.push(1);
                        if (currentPage > 3) pages.push("...");
                        for (let i = Math.max(2, currentPage - 1); i <= Math.min(totalPages - 1, currentPage + 1); i++) {
                            pages.push(i);
                        }
                        if (currentPage < totalPages - 2) pages.push("...");
                        pages.push(totalPages);
                    }
                    %>
                    
                    <% pages.forEach(p => { %>
                        <% if (p === "...") { %>
                            <span class="px-2 py-2 text-slate-400 text-sm">···</span>
                        <% } else { %>
                            <a href="?page=<%= p %>" class="px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-200 <%= p === currentPage ? 'bg-gradient-to-r from-[#7E43E2] to-[#9B59E8] text-white shadow-md shadow-[#7E43E2]/25' : 'text-slate-600 hover:bg-[#7E43E2]/10 hover:text-[#7E43E2] border border-slate-200 hover:border-[#7E43E2]/30' %>"><%= p %></a>
                        <% } %>
                    <% }) %>
                    
                    <a href="?page=<%= Math.min(totalPages, currentPage + 1) %>" class="px-3.5 py-2 rounded-lg text-sm font-semibold transition-all duration-200 <%= currentPage === totalPages ? 'text-slate-300 pointer-events-none' : 'text-slate-600 hover:bg-[#7E43E2]/10 hover:text-[#7E43E2] border border-slate-200 hover:border-[#7E43E2]/30' %>">&raquo;</a>
                <% } %>
            </div>
        <% } %>
    </div>
</div>
<% } %>

<%- include('partials/footer') %>
